# Copy this file to .env and fill in your values.

# Required for lesson generation and the Anthropic player backend.
# Leave blank if running fully local (disable lessons in arena.py).
ANTHROPIC_API_KEY=

# Path to the Stockfish binary.
STOCKFISH_PATH=/usr/games/stockfish

# Default LM Studio endpoint. Both players use this URL unless overridden
# with --white-url / --black-url on the command line.
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# LM Studio doesn't validate the API key, but the OpenAI client requires one.
LMSTUDIO_API_KEY=lm-studio

# WebSocket port for the live visualizer.
WS_PORT=8765

# Players — edit these to swap models without touching the command line.
# Model IDs must match exactly what LM Studio reports (check /v1/models).
WHITE_NAME=Model A
WHITE_MODEL=qwen3.5-4b:v1

BLACK_NAME=Model B
BLACK_MODEL=qwen3.5-4b:v2
